---
import SectionLayout from '../layouts/SectionLayout.astro';
---

<SectionLayout id="hero">
	<div class="hero-grid">
		<div class="details">
			<p class="location">📍 Las Piñas, Philippines</p>
			<h1>Chester <br /> Alejandro.</h1>
			<p class="role">Front-end Developer</p>
			<p class="bio">
				I'm a front-end developer with over three years of experience
				building responsive, user-friendly websites. I focus on clean,
				organized code that brings designs to life and ensures a
				seamless user experience. My goal is to create web applications
				that are genuinely useful — solutions that help people and make
				the web a more accessible place.
			</p>

			<div class="ctas">
				<a href="#projects" class="cta primary">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
						></path>
						<circle cx="12" cy="12" r="3"></circle>
					</svg>
					View My Projects
				</a>
				<a href="#contact" class="cta secondary">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect x="2" y="4" width="20" height="16" rx="2"></rect>
						<polyline points="2,4 12,13 22,4"></polyline>
					</svg>
					Contact Me
				</a>
			</div>
		</div>

		<div class="photo">
			<figure>
				<img src="/images/chester.jpg" alt="Chester Alejandro" />
			</figure>
			<ul class="skills">
				<li>HTML</li>
				<li>CSS</li>
				<li>JavaScript</li>
				<li>Responsive Design</li>
				<li>UI/UX Basics</li>
			</ul>
		</div>
	</div>
</SectionLayout>

<style>
	.hero-grid {
		display: grid;
		grid-template-columns: 3fr 2fr;
		align-items: start;
		gap: var(--space-16);
	}

	/* ── Details ── */
	.details {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.location {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		color: var(--clr-text-muted);
		letter-spacing: 0.04em;
	}

	h1 {
		font-family: var(--font-display);
		font-size: var(--text-5xl);
		font-weight: 700;
		color: var(--clr-text);
		line-height: 0.92;
	}

	h1 span {
		color: var(--clr-accent);
	}

	.role {
		text-transform: uppercase;
		font-family: var(--font-display);
		font-size: var(--text-base);
		font-weight: 500;
		color: var(--clr-accent);
		letter-spacing: 0.03em;
		margin-top: var(--space-2);
	}

	.bio {
		font-size: var(--text-lg);
		color: var(--clr-text-muted);
		line-height: 1.8;
		max-width: 55ch;
		margin-top: var(--space-4);
	}

	.ctas {
		display: flex;
		gap: var(--space-3);
		flex-wrap: wrap;
		margin-top: var(--space-2);
	}

	.cta {
		font-family: var(--font-display);
		font-size: var(--text-sm);
		font-weight: 600;
		padding: var(--space-3) var(--space-6);
		border-radius: var(--radius-md);
		letter-spacing: 0.03em;
		transition:
			background var(--transition-fast),
			color var(--transition-fast),
			border-color var(--transition-fast);
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
	}

	.cta svg {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	.cta.primary {
		background: var(--clr-accent);
		color: var(--clr-primary);
		border: 1px solid transparent;
	}

	.cta.secondary {
		background: transparent;
		color: var(--clr-text);
		border: 1px solid var(--clr-border-strong);
	}

	.cta.primary:hover {
		background: transparent;
		color: var(--clr-accent);
		border: 1px solid var(--clr-accent);
	}

	.cta.secondary:hover {
		background: var(--clr-accent);
		color: var(--clr-primary);
		border-color: var(--clr-accent);
	}

	/* ── Photo ── */
	.photo {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-6);
	}

	figure {
		width: 260px;
		height: 260px;
		border-radius: var(--radius-md);
		overflow: hidden;
		border: 3px solid var(--clr-border-strong);
		flex-shrink: 0;
		margin-top: var(--space-4);
	}

	figure img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(100%);
	}

	/* ── Skills ── */
	.skills {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-2);
	}

	.skills li {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--clr-text-muted);
		background: var(--clr-surface);
		border: 1px solid var(--clr-border);
		border-radius: var(--radius-full);
		padding: var(--space-1) var(--space-3);
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.hero-grid {
			grid-template-columns: 1fr;
		}

		.details {
			text-align: center;
		}

		.photo {
			order: -1;
		}

		h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
