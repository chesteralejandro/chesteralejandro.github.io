---
import SectionLayout from '../layouts/SectionLayout.astro';
---

<SectionLayout id="hero">
	<div class="details">
		<div class="location">
			<span>Las Piñas, Philippines</span>
		</div>
		<h1>Chester Alejandro</h1>
		<p class="role">Front-end Developer</p>
		<p class="bio">
			I'm a front-end developer with over three years of experience
			building responsive, user-friendly websites. I focus on clean,
			organized code that brings designs to life and ensures a seamless
			user experience. My goal is to create web applications that are
			genuinely useful — solutions that help people and make the web a
			more accessible place.
		</p>
		<p class="hobbies">
			When I'm not coding, I enjoy watching anime, online shopping, and
			keeping things neat and tidy.
		</p>
		<div class="ctas">
			<a href="#projects" class="cta primary">View My Projects</a>
			<a href="#contact" class="cta secondary">Contact Me</a>
		</div>
	</div>
	<div class="photo">
		<figure>
			<img src="/images/chester.jpg" alt="Chester Alejandro" />
		</figure>
		<ul class="skills">
			<li>HTML</li>
			<li>CSS</li>
			<li>JavaScript</li>
			<li>Responsive Design</li>
			<li>UI/UX Basics</li>
		</ul>
	</div>
</SectionLayout>
