---
const projects = [
    {
        title: "Simple Todo List",
        description: "A clean task manager with add, complete, and delete functionality.",
        stack: ["HTML", "CSS", "JavaScript"],
        live: "https://chesteralejandro.github.io/todo_list/",
        code: "https://github.com/chesteralejandro/todo_list",
        image: "/images/projects/todo.png",
    },
    {
        title: "Mini Pacman Game",
        description: "A browser-based Pacman clone built with vanilla JavaScript and Canvas.",
        stack: ["HTML", "CSS", "JavaScript"],
        live: "https://chesteralejandro.github.io/simple_pacman_game/",
        code: "https://github.com/chesteralejandro/simple_pacman_game",
        image: "/images/projects/pacman.jpg",
    },
    {
        title: "Minted PH Website",
        description: "A brand website built for a local Philippine business.",
        stack: ["HTML", "CSS", "JavaScript"],
        live: "https://www.youtube.com/watch?v=A5ujLrpAp-c",
        code: null,
        image: "/images/projects/mintedph.jpg",
    },
    {
        title: "Loaf and Roll Website",
        description: "A website for a local food business. Currently in progress.",
        stack: ["HTML", "CSS", "JavaScript"],
        live: null,
        code: null,
        image: null,
    },
];
---

<section id="projects">
    <div class="container">
        <div class="heading">
            <span class="label">Projects</span>
            <h2>Selected Projects</h2>
        </div>
        <div class="grid">
            {projects.map((project, index) => (
                <article>
                    <div class="thumbnail">
                        {project.image
                            ? <img src={project.image} alt={project.title} />
                            : <div class="placeholder">Coming Soon</div>
                        }
                    </div>
                    <div class="content">
                        <div class="top">
                            <span class="number">
                                {String(index + 1).padStart(2, '0')}
                            </span>
                            <h3>{project.title}</h3>
                            <p>{project.description}</p>
                            <ul class="stack">
                                {project.stack.map((tech) => (
                                    <li>{tech}</li>
                                ))}
                            </ul>
                        </div>
                        <div class="links">
                            {project.live &&
                                <a href={project.live} target="_blank" rel="noopener noreferrer">
                                    View Live ↗
                                </a>
                            }
                            {project.code &&
                                <a href={project.code} target="_blank" rel="noopener noreferrer">
                                    View Code ↗
                                </a>
                            }
                            {!project.live && !project.code &&
                                <span class="soon">Coming Soon</span>
                            }
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    section {
        padding: 120px 0;
        border-top: 1px solid var(--clr-border);
    }

    .container {
        width: min(1200px, 92%);
        margin-inline: auto;
    }

    .heading {
        margin-bottom: 4rem;
    }

    .label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--clr-accent);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.75rem;
    }

    .label::before {
        content: '';
        display: inline-block;
        width: 24px;
        height: 1px;
        background: var(--clr-accent);
    }

    h2 {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 400;
        color: var(--clr-white);
        line-height: 1.1;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--clr-border);
        border: 1px solid var(--clr-border);
    }

    article {
        background: var(--clr-bg);
        display: flex;
        flex-direction: column;
        transition: background 0.3s ease;
    }

    article:hover {
        background: var(--clr-surface);
    }

    .thumbnail {
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-bottom: 1px solid var(--clr-border);
    }

    .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: grayscale(30%);
        transition: transform 0.5s ease, filter 0.5s ease;
    }

    article:hover .thumbnail img {
        transform: scale(1.04);
        filter: grayscale(0%);
    }

    .placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--clr-muted);
        background: var(--clr-surface);
    }

    .content {
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex: 1;
        gap: 1.5rem;
    }

    .number {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: var(--clr-muted);
        display: block;
        margin-bottom: 0.5rem;
    }

    h3 {
        font-family: 'DM Serif Display', serif;
        font-size: 1.35rem;
        font-weight: 400;
        color: var(--clr-white);
        margin-bottom: 0.6rem;
    }

    p {
        font-size: 0.9rem;
        color: var(--clr-text-dim);
        line-height: 1.7;
        margin-bottom: 1rem;
    }

    .stack {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        padding: 0;
        margin: 0;
    }

    .stack li {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--clr-text-dim);
        border: 1px solid var(--clr-border);
        padding: 0.25rem 0.65rem;
    }

    .links {
        display: flex;
        gap: 1rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--clr-border);
    }

    .links a {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--clr-accent);
        text-decoration: none;
        transition: opacity 0.3s ease;
    }

    .links a:hover {
        opacity: 0.7;
    }

    .soon {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--clr-muted);
    }

    @media (max-width: 768px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>