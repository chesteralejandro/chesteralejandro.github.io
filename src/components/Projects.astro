---
import SectionLayout from '../layouts/SectionLayout.astro';

const projects = [
	{
		title: 'Typr',
		description:
			'A lightweight declarative typewriter effect library for the browser. Animate text with simple HTML attributes. No dependencies.',
		stack: ['HTML', 'CSS', 'JavaScript'],
		live: 'https://chesteralejandro.github.io/typr',
		code: 'https://github.com/chesteralejandro/typr',
		image: null,
	},
	{
		title: 'Cell Defender',
		description:
			'A retro grid-based game where you control a white blood cell, collect pills, and avoid enemy germs.',
		stack: ['HTML', 'CSS', 'JavaScript'],
		live: 'https://chesteralejandro.github.io/frontend-project-gallery/personal-projects/cell-defender/',
		code: 'https://github.com/chesteralejandro/cell-defender',
		image: null,
	},
	{
		title: 'Orbitarium',
		description:
			'An interactive Solar System simulation built with pure HTML, CSS, and JavaScript, showcasing smooth orbital motion, dynamic camera focus, and immersive audio-driven exploration.',
		stack: ['HTML', 'CSS', 'JavaScript'],
		live: 'https://chesteralejandro.github.io/frontend-project-gallery/personal-projects/orbitarium/',
		code: 'https://github.com/chesteralejandro/orbitarium',
		image: null,
	},
];
---

<SectionLayout id="projects">
	<header class="section-header">
		<span class="label">Projects</span>
		<h2>Selected Projects</h2>
	</header>

	<div class="project-list">
		{
			projects.map((project, index) => (
				<article class="card">
					<div class="thumbnail">
						{project.image ? (
							<img src={project.image} alt={project.title} />
						) : (
							<img
								src="/images/placeholder.webp"
								alt="Coming Soon"
								class="placeholder"
							/>
						)}
					</div>

					<div class="content">
						<div class="content-top">
							<span class="index">
								{String(index + 1).padStart(2, '0')}
							</span>
							<h3>{project.title}</h3>
							<p class="description">{project.description}</p>
							<ul class="stack">
								{project.stack.map((tech) => (
									<li>{tech}</li>
								))}
							</ul>
						</div>
						<div class="actions">
							<a
								href={project.live}
								target="_blank"
								rel="noopener noreferrer"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<circle cx="12" cy="12" r="10" />
									<polygon points="10,8 16,12 10,16" />
								</svg>
								View Live
							</a>
							<a
								href={project.code}
								target="_blank"
								rel="noopener noreferrer"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
								</svg>
								View Code
							</a>
						</div>
					</div>
				</article>
			))
		}
	</div>
</SectionLayout>

<style>
	/* ── Section Header ── */
	.section-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		margin-bottom: var(--space-12);
	}

	.label {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--clr-accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	h2 {
		font-family: var(--font-display);
		font-size: var(--text-3xl);
		font-weight: 700;
		color: var(--clr-text);
	}

	/* ── Project List ── */
	.project-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
	}

	/* ── Card ── */
	.card {
		display: grid;
		grid-template-columns: 2fr 3fr;
		border: 1px solid var(--clr-border);
		border-radius: var(--radius-lg);
		background: var(--clr-surface);
		overflow: hidden;
	}

	/* ── Thumbnail ── */
	.thumbnail {
		background: var(--clr-bg-alt);
		display: flex;
		align-items: center;
		justify-content: center;
		align-self: stretch;
	}

	.thumbnail img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.placeholder {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* ── Content ── */
	.content {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: var(--space-8);
		gap: var(--space-6);
	}

	.content-top {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.index {
		font-family: var(--font-display);
		font-size: var(--text-xs);
		font-weight: 700;
		color: var(--clr-accent);
		letter-spacing: 0.1em;
		opacity: 0.75;
	}

	h3 {
		font-family: var(--font-display);
		font-size: var(--text-2xl);
		font-weight: 700;
		color: var(--clr-text);
	}

	.description {
		font-size: var(--text-sm);
		color: var(--clr-text-muted);
		line-height: 1.8;
		display: -webkit-box;
		-webkit-line-clamp: 4;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ── Stack ── */
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.stack li {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--clr-text-muted);
		background: var(--clr-bg-alt);
		border: 1px solid var(--clr-border);
		border-radius: var(--radius-full);
		padding: var(--space-1) var(--space-3);
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	/* ── Actions ── */
	.actions {
		display: flex;
		gap: var(--space-3);
	}

	.actions a {
		font-family: var(--font-display);
		font-size: var(--text-sm);
		font-weight: 600;
		padding: var(--space-2) var(--space-6);
		border-radius: var(--radius-full);
		letter-spacing: 0.03em;
		transition:
			background var(--transition-fast),
			color var(--transition-fast),
			border-color var(--transition-fast);
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
	}

	.actions a svg {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	.actions a:first-child {
		background: var(--clr-accent);
		color: var(--clr-primary);
		border: 1px solid transparent;
	}

	.actions a:last-child {
		background: transparent;
		color: var(--clr-text);
		border: 1px solid var(--clr-border-strong);
	}

	.actions a:first-child:hover {
		background: transparent;
		color: var(--clr-accent);
		border: 1px solid var(--clr-accent);
	}

	.actions a:last-child:hover {
		background: var(--clr-accent);
		color: var(--clr-primary);
		border-color: var(--clr-accent);
	}

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.card {
			grid-template-columns: 1fr;
		}

		.thumbnail {
			min-height: 200px;
		}
	}
</style>
